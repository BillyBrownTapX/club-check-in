# ─────────────────────────────────────────────────────────────────────────────
# Attendance HQ — environment variable template.
#
# Copy this file to `.env` and fill in real values for local development.
# The real `.env` is gitignored and must NEVER be committed.
#
# In production (Cloudflare Workers/Pages) these are configured via:
#   • `wrangler.jsonc` `vars` for non-secret values, or
#   • `wrangler secret put <NAME>` for secret values (always use this for
#     SUPABASE_SERVICE_ROLE_KEY).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Public Supabase config (safe to ship to the browser) ────────────────────
# Used by:  src/integrations/supabase/client.ts
#           src/integrations/supabase/auth-middleware.ts
#           src/integrations/supabase/client.server.ts
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Vite-prefixed copies (Vite only inlines vars beginning with VITE_).
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ─── Server-only secret (NEVER ship to the browser) ──────────────────────────
# Used by:  src/integrations/supabase/client.server.ts
# Bypasses RLS — required for the public check-in flow and for any host
# mutations that go through the admin client (e.g. attendance writes,
# remove-attendance audit log, close-check-in-early). The app will throw on
# server boot if this is missing.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
